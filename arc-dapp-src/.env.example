# ============================================================
# Arc DApp - Environment Variables
# Copy this file to .env.local và điền vào giá trị thật
# KHÔNG commit file .env.local lên git
# ============================================================

# Private key của wallet EVM (MetaMask, v.v.)
# Format: 0x + 64 hex chars
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Kit Key từ Circle Console (https://console.circle.com)
# Bắt buộc cho tính năng Swap
# Format: KIT_KEY:xxx:yyy
KIT_KEY=YOUR_KIT_KEY_HERE

# (Tuỳ chọn) Alchemy API Key cho RPC tốc độ cao hơn
# Đăng ký tại: https://www.alchemy.com/
ALCHEMY_KEY=YOUR_ALCHEMY_KEY_HERE
