# ============================================================
# Arc DApp — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# EVM wallet private key — used server-side to sign bridge/swap transactions
# Format: 0x followed by 64 hex characters
# Get a testnet wallet at: https://metamask.io
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Circle App Kit key — required for Bridge and Swap via Circle SDK
# Get it at: https://console.circle.com → Create Project → API Keys
# Format: KIT_KEY:xxxxxxxx:yyyyyyyy
KIT_KEY=YOUR_KIT_KEY_HERE

# (Optional) Alchemy API key for faster RPC
# Register at: https://www.alchemy.com
ALCHEMY_KEY=YOUR_ALCHEMY_KEY_HERE
